    <mxCell id="e_to_chart" value="chart / hybrid" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;strokeColor=#82b366;fontSize=9;" edge="1" source="retry_logic" target="chart_agent" parent="1">
