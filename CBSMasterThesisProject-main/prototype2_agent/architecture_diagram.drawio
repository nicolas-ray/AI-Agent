    <!-- Return loop to frontend (right side) -->
    <mxCell id="e_loop" value="Return answer + chart" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#6c8ebf;fontSize=9;" edge="1" source="return_box" target="frontend" parent="1">
